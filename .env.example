# ---------------------------------------------------------------- Newsroom source
# "dummy" (default) reads src/data/newsletter.ts — the site works with no API running.
# "api"   reads GET {VITE_API_URL}/public/newsletters via src/services/newsroom.ts.
#
# Nothing else changes when you flip this: the adapter returns the exact `NewsArticle`
# shape the dummy data uses, verified field-by-field across all 14 articles.
VITE_NEWSROOM_SOURCE=dummy

# Only read when VITE_NEWSROOM_SOURCE=api.
VITE_API_URL=http://localhost:4000/api/v1
